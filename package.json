export const translateText = (text: string, lang: 'en' | 'pt'): string => {
  if (lang === 'en') return text;
  
  // Try exact translate
  if (questionTranslations[text]) {
    return questionTranslations[text];
  }
  if (hintTranslations[text]) {
    return hintTranslations[text];
  }
  if (categoryTranslations[text]) {
    return categoryTranslations[text];
  }

  // Fallbacks using regex patterns
  let translated = text;

  // Simple string replacements
  if (translated.includes("Green (1), Yellow (2), Red (3)")) {
    translated = translated.replace("Green (1), Yellow (2), Red (3)", "Verde (1), Amarelo (2), Vermelho (3)");
  }
  if (translated.includes("what is the sum")) {
    translated = translated.replace("what is the sum of the first", "qual é a soma dos primeiros");
    translated = translated.replace("terms?", "termos?");
  }
  if (translated.includes("what is the total number of")) {
    translated = translated.replace("what is the total number of", "qual é o número total de");
  }
  if (translated.includes("In the game")) {
    translated = translated.replace("In the game", "No jogo");
  }
  if (translated.includes("how many possible")) {
    translated = translated.replace("how many possible", "quantas possíveis");
  }
  if (translated.includes("minimum number of moves")) {
    translated = translated.replace("minimum number of moves", "número mínimo de movimentos");
  }
  if (translated.includes("What is the next number?")) {
    translated = translated.replace("What is the next number?", "Qual é o próximo número?");
  }

  return translated;
};
